# ─────────────────────────────────────────────
# Plantilla de variables de entorno
# ─────────────────────────────────────────────

# SentinelWatch - Plantilla de variables de entorno
# Copia este archivo como .env y rellena tus valores.
# NUNCA hagas commit del archivo .env real.

# Google Earth Engine
# Obtén tu project ID en: https://console.cloud.google.com
GEE_PROJECT_ID=your-google-cloud-project-id

# PostgreSQL / PostGIS (Docker)
POSTGRES_DB=deforestation_db
POSTGRES_USER=geouser
POSTGRES_PASSWORD=change_me_to_a_secure_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# LM Studio (servidor local OpenAI-compatible)
# Asegúrate de que LM Studio esté corriendo antes de ejecutar report_agent.py
LM_STUDIO_URL=http://localhost:1234/v1
